{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/check-subscriptions",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-sla",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/trial-check",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/health",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/payout",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/audit",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/platform-monitor",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/sentinel",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/newsletter-weekly",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/scripts-readiness-alert",
      "schedule": "30 14 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://zairyx.com.br"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}
